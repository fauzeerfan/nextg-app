generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUM
//////////////////////////////////////////////////////

enum StationCode {
  CUTTING_ENTAN
  CUTTING_POND
  CP
  SEWING
  QC
  PACKING
  FG
}

enum ProductionStatus {
  WIP
  DONE
  HOLD
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id              String   @id @default(uuid())
  username        String   @unique
  password        String
  fullName        String
  role            String
  station         String?                     // legacy
  allowedStations Json?                       // JSON array
  department      String?                     // dept code
  jobTitle        String?                     // job title
  lineCode        String?                     // line
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ========== NEW: Login Status Enum & Log ==========
model UserLoginLog {
  id           String   @id @default(uuid())
  userId       String?
  username     String
  timestamp    DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  status       LoginStatus
  errorMessage String?
  station      String?

  @@index([timestamp])
  @@index([userId])
  @@index([username])
}

enum LoginStatus {
  SUCCESS
  FAILED
}

//////////////////////////////////////////////////////
// LINE MASTER
//////////////////////////////////////////////////////

model LineMaster {
  id                String  @id @default(uuid())
  code              String  @unique
  name              String
  description       String?
  patternMultiplier Int     @default(1)
  ngCategories      Json?   // untuk Check Panel
  qcNgCategories    Json?   // <-- baru untuk Quality Control
  sewingConfig      Json?   // <-- NEW: menyimpan konfigurasi sewing start/finish
  packingConfig      Json?   // { "packSize": 50 }
  

  stations         LineStation[]
  patterns         PatternMaster[]
  productionOrders ProductionOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LineStation {
  id       String      @id @default(uuid())
  lineId   String
  station  StationCode
  required Boolean     @default(true)
  order    Int

  line LineMaster @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([lineId, station])
}

//////////////////////////////////////////////////////
// PATTERN MASTER
//////////////////////////////////////////////////////

model PatternMaster {
  id        String @id @default(uuid())
  styleCode String
  lineId    String

  imgSetGood String?
  imgSetNg   String?

  line  LineMaster    @relation(fields: [lineId], references: [id], onDelete: Cascade)
  parts PatternPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([styleCode, lineId])
}

model PatternPart {
  id        String  @id @default(uuid())
  patternId String
  name      String
  imgGood   String?
  imgNg     String?

  pattern PatternMaster @relation(fields: [patternId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// PRODUCTION ORDER (CORE BRAIN)
//////////////////////////////////////////////////////

model ProductionOrder {
  id        String @id @default(uuid())
  opNumber  String @unique
  lineId    String
  styleCode String

  itemNumberFG String
  itemNameFG   String?

  qtyOp Int

  // Cutting quantities
  qtyEntan       Int @default(0)
  qtySentToPond  Int @default(0)

  // Pond quantities
  qtyPond  Int @default(0)
  qtyPondNg Int @default(0)


  // Check Panel
  qtyCP    Int @default(0)
  cpGoodQty  Int @default(0)
  cpNgQty    Int @default(0)
  readyForCP   Boolean @default(false)
  setsReadyForSewing Int @default(0)
  allPatternsCompleted  Boolean @default(false)

  // Sewing
  qtySewingIn  Int @default(0)
  qtySewingOut Int @default(0)

  sewingStartProgress SewingStartProgress[]
  sewingFinishProgress SewingFinishProgress[]

  // Quality Control
  qtyQC      Int @default(0)
  qcNgQty    Int @default(0)

  // Packing  
  qtyPacking Int @default(0)
  qtyFG      Int @default(0)

  status         ProductionStatus @default(WIP)
  currentStation StationCode?

  line LineMaster @relation(fields: [lineId], references: [id])

  // Relations
  trackings     ProductionTracking[]
  logs          ProductionLog[]
  packingItems  PackingItem[]
  fgItems       FGStockItem[]
  shipmentItems ShipmentItem[]
  cuttingBatches CuttingBatch[]
  patternProgress PatternProgress[]
  checkPanelInspections CheckPanelInspection[]
  qcInspections         QcInspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PatternProgress {
  id           String   @id @default(uuid())
  opId         String
  patternIndex Int
  patternName  String
  target       Int
  good         Int      @default(0)
  ng           Int      @default(0)
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, patternIndex])
}

// New model
model CuttingBatch {
  id        String   @id @default(uuid())
  opId      String
  batchNumber Int      // sequential per OP, starting at 1
  qty       Int
  qrCode    String   @unique
  createdAt DateTime @default(now())
  printed   Boolean  @default(false) // optional, for tracking reprints

  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, batchNumber])
}

//////////////////////////////////////////////////////
// TRACKING PER STATION
//////////////////////////////////////////////////////

model ProductionTracking {
  id      String      @id @default(uuid())
  opId    String
  station StationCode

  goodQty Int @default(0)
  ngQty   Int @default(0)

  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([opId, station])
}

//////////////////////////////////////////////////////
// PRODUCTION LOG (HISTORY)
//////////////////////////////////////////////////////

model ProductionLog {
  id      String      @id @default(uuid())
  opId    String
  station StationCode
  type    String // IN OUT NG MOVE
  qty     Int
  note    String?

  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// PACKING SESSION
//////////////////////////////////////////////////////

model PackingSession {
  id        String   @id @default(uuid())
  fgNumber  String
  totalQty  Int      @default(0)
  status    String   @default("OPEN")   // OPEN, CLOSED
  qrCode    String?                      // menyimpan kode QR untuk box
  printed   Boolean  @default(false)     // status cetak ulang
  receivedAt DateTime?                    // <-- TANDAI SAAT DITERIMA DI FINISHED GOODS
  items     PackingItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PackingItem {
  id        String @id @default(uuid())
  sessionId String
  opId      String
  qty       Int

  session PackingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  op      ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// FG STOCK (FIFO)
//////////////////////////////////////////////////////

model FGStock {
  id       String @id @default(uuid())
  fgNumber String @unique
  totalQty Int    @default(0)

  items FGStockItem[]

  updatedAt DateTime @updatedAt
}

model FGStockItem {
  id   String @id @default(uuid())
  fgId String
  opId String
  qty  Int

  fg FGStock         @relation(fields: [fgId], references: [id], onDelete: Cascade)
  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// SHIPPING
//////////////////////////////////////////////////////

model Shipment {
  id         String @id @default(uuid())
  suratJalan String
  fgNumber   String
  totalQty   Int

  items ShipmentItem[]

  createdAt DateTime @default(now())
}

model ShipmentItem {
  id         String @id @default(uuid())
  shipmentId String
  opId       String
  qty        Int

  shipment Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  op       ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// CUTTING SYNC LOG
//////////////////////////////////////////////////////

model CuttingSyncLog {
  id       String @id @default(uuid())
  opNumber String
  qty      Int
  status   String
  rawData  Json?

  createdAt DateTime @default(now())
}

model IotDevice {
  id        String @id @default(uuid())
  deviceId  String @unique
  name      String?
  mode      String
  station   StationCode
  lineCode  String
  config    Json?   // NEW: menyimpan info seperti { sewingIndex: 1, type: "start", patterns: [0,1] }
  lastSeen  DateTime?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SewingStartProgress {
  id          String @id @default(uuid())
  opId        String
  startIndex  Int
  qty         Int @default(0)
  op          ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, startIndex])
}

model SewingFinishProgress {
  id          String @id @default(uuid())
  opId        String
  finishIndex Int
  qty         Int @default(0)
  op          ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, finishIndex])
}

model CheckPanelInspection {
  id           String @id @default(uuid())
  opId         String
  patternIndex Int
  patternName  String
  good         Int @default(0)
  ng           Int @default(0)
  ngReasons    Json?  // array of reasons
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)

  @@unique([opId, patternIndex])
}

model QcInspection {
  id        String   @id @default(uuid())
  opId      String
  good      Int      @default(0)
  ng        Int      @default(0)
  ngReasons Json?    // array of reasons
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  op ProductionOrder @relation(fields: [opId], references: [id], onDelete: Cascade)
}

// ========== NEW: Employee Management ==========
model Employee {
  id          String   @id @default(uuid())
  nik         String   @unique
  fullName    String
  gender      String   // "Laki-laki", "Perempuan"
  jobTitle    String
  lineCode    String   // e.g., "K1YH"
  station     String   // station code from StationCode enum
  section     String
  department  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances ManpowerAttendance[]
  mutations   EmployeeMutationHistory[]
}

model EmployeeMutationHistory {
  id             String   @id @default(uuid())
  employeeId     String
  nik            String
  fullName       String   // snapshot nama saat mutasi
  oldLineCode    String
  newLineCode    String
  oldStation     String
  newStation     String
  oldSection     String
  newSection     String
  oldDepartment  String
  newDepartment  String
  oldJobTitle    String
  newJobTitle    String
  mutationDate   DateTime @default(now())
  note           String?  // keterangan mutasi
  mutatedBy      String?  // username user yang melakukan mutasi

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([nik])
  @@map("employee_mutation_history")
}

// ========== NEW: Manpower Attendance ==========
model ManpowerAttendance {
  id         String   @id @default(uuid())
  nik        String
  tanggal    DateTime @map("date") // only date part (use date only)
  lineCode   String
  station    String
  scanTime   DateTime @default(now())
  employee   Employee @relation(fields: [nik], references: [nik], onDelete: Cascade)

  @@unique([nik, tanggal])
}

model TargetSetting {
  id             String   @id @default(uuid())
  lineCode       String
  station        String   @default("SEWING")
  indexValue     Float
  effectiveDate  DateTime @map("effective_date")
  note           String?
  isActive       Boolean  @default(true)   // <-- tambahkan baris ini
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([lineCode, station, effectiveDate])
  @@map("target_settings")
}