/* 2. Import Tailwind CSS */
@import "tailwindcss";

/* --- CRITICAL FIX FOR DARK MODE --- */
@variant dark (&:where(.dark, .dark *));

@theme {
  /* Font Override */
  --font-sans: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;

  /* Custom Colors */
