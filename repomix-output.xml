                      )}
                    </button>
                  );
                })}
              </div>
            </div>
          ))}
        </nav>

        {/* USER PROFILE & SETTINGS - lebih compact */}
        <div className={`border-t border-slate-100 dark:border-slate-800/50 transition-all duration-300 shrink-0 ${
