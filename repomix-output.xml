      {qr && (
        <>
          {/* ========================================================= */}
          {/* 1. VERSI CETAK MESIN */}
          {/* ========================================================= */}
          <div className="hidden print:flex w-[7.9cm] h-[3.8cm] bg-white text-black m-0 p-0 box-border flex-col items-center justify-center overflow-hidden fixed top-0 left-0 z-[9999]">
