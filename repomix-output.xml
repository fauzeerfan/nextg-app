      isMobile
        ? (isOpen ? 'translate-x-0' : '-translate-x-full')
        : (isOpen ? 'w-64 lg:w-72' : 'w-16 lg:w-20')
    }`}>
      {/* Header / Logo */}
      <div className="flex items-center h-20 lg:h-24 border-b border-slate-200/50 dark:border-slate-800/50 shrink-0 px-4 lg:px-5">
