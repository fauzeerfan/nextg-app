          {!isCollapsed && (
            <div className="flex items-center gap-2 lg:gap-3 mb-3 lg:mb-4 pt-3 lg:pt-4">
              <div className="relative">
                {/* AVATAR IDENTICON - SAMA SEPERTI DI USER MANAGEMENT */}
                <img
